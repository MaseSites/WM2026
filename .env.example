# ─────────────────────────────────────────────────────────────────────────
# WorldMap 26 — live data (optional)
#
# Without a key the app runs on the bundled real snapshot in src/lib/data.
# Set an API-Football (api-sports.io) key to fetch LIVE results, which merge
# over the snapshot and refresh automatically every 60 seconds (ISR).
#
# Get a key: https://dashboard.api-football.com/
# NOTE: the API-Football *Free* plan only allows seasons 2022–2024, so live
# 2026 World Cup data needs a paid plan. Set the season you have access to.
# ─────────────────────────────────────────────────────────────────────────

API_FOOTBALL_KEY=
API_FOOTBALL_SEASON=2026
API_FOOTBALL_LEAGUE=1

# Optional: protect the on-demand refresh endpoint POST /api/revalidate?secret=...
REVALIDATE_SECRET=
