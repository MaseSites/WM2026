# ─────────────────────────────────────────────────────────────────────────
# WorldMap 26 — Live-Daten (optional)
#
# Ohne Key läuft die Seite auf dem eingebauten Snapshot in src/lib/data.
# Mit einem football-data.org-Key holt sie ECHTE Live-Ergebnisse, die sich
# automatisch alle 60 Sekunden aktualisieren (ISR).
#
# Kostenlosen Key holen: https://www.football-data.org/client/register
# ─────────────────────────────────────────────────────────────────────────

# Dein API-Key (nach dem = einfügen, ohne Anführungszeichen):
FOOTBALL_DATA_API_KEY=

# Optional: Saison der WM festlegen (Startjahr). Bei football-data.org meist 2026.
FOOTBALL_DATA_SEASON=2026

# Optional: schützt den Sofort-Aktualisieren-Endpunkt POST /api/revalidate?secret=...
REVALIDATE_SECRET=
